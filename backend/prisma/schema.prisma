generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String                   @id @default(uuid())
  email          String                   @unique
  password       String
  isPremium      Boolean                  @default(false)
  premiumUntil   DateTime?
  premiumPlan    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  simulations    Simulation[]
  subscription   Subscription?
  collaborations SimulationCollaborator[]
  comments       SimulationComment[]
  invitesCreated SimulationInvite[]       @relation("InviteCreator")
  ownedGroups    TripGroup[]              @relation("GroupOwner")
  groupMembers   TripGroupMember[]
  groupSimulations  GroupSimulation[]
  groupVotes        GroupVote[]
}

model TripGroup {
  id           String              @id @default(uuid())
  name         String
  emoji        String              @default("🌍")
  ownerId      String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  owner        User                @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      TripGroupMember[]
  invites      TripGroupInvite[]
  simulations  GroupSimulation[]
}

model GroupSimulation {
  id           String     @id @default(uuid())
  groupId      String
  simulationId String
  proposedBy   String
  createdAt    DateTime   @default(now())
  group        TripGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  proposer     User       @relation(fields: [proposedBy], references: [id], onDelete: Cascade)
  votes        GroupVote[]

  @@unique([groupId, simulationId])
}

model GroupVote {
  id                String          @id @default(uuid())
  groupSimulationId String
  userId            String
  vote              String          // 'up' | 'down'
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  groupSimulation   GroupSimulation @relation(fields: [groupSimulationId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupSimulationId, userId])
}

model TripGroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  role      String    @default("member")
  joinedAt  DateTime  @default(now())
  group     TripGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model TripGroupInvite {
  id         String    @id @default(uuid())
  groupId    String
  token      String    @unique
  createdBy  String
  expiresAt  DateTime
  usedCount  Int       @default(0)
  createdAt  DateTime  @default(now())
  group      TripGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Simulation {
  id                   String                   @id @default(uuid())
  userId               String
  destination          String
  departureCity        String                   @default("")
  startDate            String                   @default("")
  endDate              String                   @default("")
  duration             Int
  people               Int
  budget               Float
  budgetData           String?                  @db.Text
  aiTips               String?                  @db.Text
  itinerary            String?                  @db.Text
  createdAt            DateTime                 @default(now())
  priceAlertEnabled    Boolean                  @default(false)
  priceAlertThreshold  Float                    @default(10)
  lastPriceTotal       Float?
  lastPriceCheckAt     DateTime?
  // Multi-stop trips (e.g. Tokyo + Kyoto + Osaka). JSON array of { name, nights }.
  stops                String?                  @db.Text
  // Host stay flag — when true, accommodation cost is set to 0.
  hostStay             Boolean                  @default(false)
  // Radius (km) around the arrival city for activities/hotels search.
  searchRadiusKm       Int                      @default(50)
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots            PriceSnapshot[]
  collaborators        SimulationCollaborator[]
  invites              SimulationInvite[]
  comments             SimulationComment[]
  groupProposals       GroupSimulation[]
}

model PriceSnapshot {
  id           String     @id @default(uuid())
  simulationId String
  total        Float
  flightPrice  Float
  hotelPrice   Float
  breakdown    String?    @db.Text
  checkedAt    DateTime   @default(now())
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([simulationId, checkedAt])
}

model SimulationCollaborator {
  id           String     @id @default(uuid())
  simulationId String
  userId       String
  role         String     @default("editor")
  createdAt    DateTime   @default(now())
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([simulationId, userId])
}

model SimulationInvite {
  id           String     @id @default(uuid())
  simulationId String
  token        String     @unique
  createdBy    String
  expiresAt    DateTime
  usedCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  creator      User       @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}

model SimulationComment {
  id            String     @id @default(uuid())
  simulationId  String
  userId        String
  dayIndex      Int?
  activityIndex Int?
  text          String     @db.Text
  createdAt     DateTime   @default(now())
  simulation    Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([simulationId, createdAt])
}

model Subscription {
  id               String   @id @default(uuid())
  userId           String   @unique
  stripeCustomerId String
  stripeSubscriptionId String?
  status           String   @default("inactive")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
