DATABASE_URL="postgresql://user:password@localhost:5432/smartbudget?schema=public"
JWT_SECRET="your-super-secret-jwt-key"
OPENAI_API_KEY="sk-your-openai-api-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PRICE_ID="price_your-stripe-price-id"
CLIENT_URL="http://localhost:3000"
PORT=4000

# Real flight + hotel prices via Google Flights + Google Hotels (PRIMARY)
# Sign up at https://serpapi.com/users/sign_up — instant (Google OAuth)
# Free tier: 100 searches/month (counts flights + hotels together)
# Paid: $75/mo for 5000 searches (~1.5¢/search), scales to enterprise
SERPAPI_KEY=""

# Real flight + hotel prices (fallback #1) — https://developers.amadeus.com/register
# Free tier: 2000 calls/month per endpoint. Signup currently restricted.
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
AMADEUS_ENV="test"  # "test" for free sandbox, "production" for live data

# Real flight prices (fallback #2) — https://tequila.kiwi.com/portal/register
# Currently closed to new signups. Leave empty if unavailable.
KIWI_API_KEY=""

# Real flight + hotel prices (fallback #3) — https://rapidapi.com/apiheya/api/sky-scrapper
# Free tier: 100 requests/month
RAPIDAPI_KEY=""

# SMTP for price alerts + invitation emails (optional in dev — emails logged if unset)
# For Gmail: use App Password https://myaccount.google.com/apppasswords
# For prod: Resend/SendGrid/Mailgun via SMTP also work.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SmartBudget <no-reply@smartbudget.app>"

# Price alert cron schedule (default: every day at 8am)
PRICE_ALERT_CRON="0 8 * * *"
