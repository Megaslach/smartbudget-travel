# Optional API keys for higher-quality destination + activity images.
# If neither is set, the app falls back to Wikipedia + LoremFlickr.
#
# Pexels (best quality, 200 req/h free): https://www.pexels.com/api/
EXPO_PUBLIC_PEXELS_KEY=

# Pixabay (alternative, 5000 req/h free): https://pixabay.com/api/docs/
EXPO_PUBLIC_PIXABAY_KEY=

# Override the API base URL (defaults to production Vercel)
# EXPO_PUBLIC_API_URL=https://smartbudget-api.vercel.app/api
