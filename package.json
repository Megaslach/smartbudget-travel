{
  "name": "smartbudget-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "build:frontend": "npm run build --workspace=@smartbudget/web",
    "build:backend": "npm run build --workspace=@smartbudget/api",
    "build:shared": "npm run build --workspace=@smartbudget/shared",
    "build": "npm run build:shared && npm run build:backend",
    "start": "npm run start --workspace=@smartbudget/api",
    "dev:web": "npm run dev --workspace=@smartbudget/web",
    "dev:api": "npm run dev --workspace=@smartbudget/api",
    "dev:mobile": "npm run start --workspace=@smartbudget/mobile"
  }
}
